{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "3.0.12",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://*.youtube.com/*",
    "https://*.googlevideo.com/*",
    "https://*.c.youtube.com/*",
    "https://*.googleusercontent.com/*",
    "https://storage.googleapis.com/*",
    "https://*.ytimg.com/*",
    "https://*.ggpht.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YouTube Music DL",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}